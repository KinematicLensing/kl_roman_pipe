# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# Data (keep config and readme)
data/*
!data/cyverse/*.conf
!data/cyverse/README.md

# Test outputs
tests/out/

# IDE
.vscode/

# Docs (generated notebooks)
docs/tutorials/*.ipynb

# Working plan docs default to ignored; use `git add -f docs/plans/<file>.md`
# to track specific plans. Keep the dir itself via .gitkeep.
docs/plans/*
!docs/plans/.gitkeep

# macOS
.DS_Store
